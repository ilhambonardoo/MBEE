// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OPERATOR
}

enum JenisKelamin {
  JANTAN
  BETINA
}

model User {
  id String @id @default(cuid())
  nama String @db.VarChar(255)
  username String @unique
  email String @unique
  password String
  role Role @default(OPERATOR)

  kambing Kambing[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Kambing{
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  kode_kambing String @unique
  jenis_kambing String
  beratAwal Float
  jenis_kelamin JenisKelamin?
  tgl_lahir DateTime?
  tgl_Masuk DateTime @default(now())

  riwayatBerat RiwayatBerat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RiwayatBerat{
  id String @id @default(cuid())
  berat Float
  kambingId String
  kambing Kambing @relation(fields: [kambingId], references: [id], onDelete: Cascade)
  tgl_cek DateTime @default(now())

  createdAt DateTime @default(now())
}
